<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ardin.BoomDaad.MainPage"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label Text="BoomDaad"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#222" />

            <Label Text="نمایش سطح صدای محیط"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="#666" />

            <Frame CornerRadius="20"
                   Padding="20"
                   BackgroundColor="White"
                   HasShadow="True">
                <VerticalStackLayout Spacing="15">

                    <Label Text="سطح صدا"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#333" />

                    <Label x:Name="AudioLevelLabel"
                           Text="0"
                           FontSize="40"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#007ACC" />

                    <ProgressBar x:Name="AudioLevelProgress"
                                 Progress="0"
                                 HeightRequest="10"
                                 ProgressColor="#007ACC" />
                </VerticalStackLayout>
            </Frame>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">

                <Button Text="Start"
                        x:Name="StartButton"
                        BackgroundColor="#28A745"
                        TextColor="White"
                        CornerRadius="10"
                        WidthRequest="120" />

                <Button Text="Stop"
                        x:Name="StopButton"
                        BackgroundColor="#DC3545"
                        TextColor="White"
                        CornerRadius="10"
                        WidthRequest="120" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
